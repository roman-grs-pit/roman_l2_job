# Generated outputs (AWS-side authoritative; pulled selectively via _pull.sh)
output/cal/*
output/logs/*
output/crds_context.log
output/smoke/asn/*
output/smoke/mosaic/*
output/smoke/catalog/*
output/full/asn/*
output/full/mosaic/*
output/full/catalog/*
output/smoke/compare/*
output/full/compare/*
output/*/sims.script
output/*/sims_raw.script
# tarballs built by archive_to_s3.sh before upload
output/*/asn.tar.gz

# Input catalog (scp'd separately, never committed)
data/*

# Generated catalog (regenerated by 00_prepare_catalog.py)
catalogs/sources.parquet

# Pointings files (regenerated by 01_build_script.sh from configs/<tag>.yaml)
/pointings_*.ecsv

# Detection-efficiency study: L2 and L3 binary products (Phase 4+) are large
# and live outside version control. Keep small artefacts (catalogs, plots,
# summaries) tracked; exclude the heavy output directories.
output/detection/l2/
output/detection/l3/
output/detection/asn/
output/detection/phase*/catalogs_*/*_segm.asdf

# Local pixi env (rebuilt per-platform)
.pixi/
crds_cache/
stpsf-data/

# Quarto render caches and output (rebuilt from source)
report/_site/
report/.quarto/
report/_freeze/
# Image assets symlinked/copied into the report tree from output/ at render time
report/full/_plots
report/full/_depth_distribution.png

# Agent / editor state
.claude/

# Editor / Python noise
__pycache__/
*.pyc
.DS_Store
